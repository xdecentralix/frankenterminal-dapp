# Frankenterminal — independent Frankencoin frontend

NEXT_PUBLIC_LANDINGPAGE_URL=https://frankencoin.com
NEXT_PUBLIC_APP_URL=https://frankenterminal.app
NEXT_PUBLIC_API_URL=https://api.frankencoin.com
NEXT_PUBLIC_PONDER_URL=https://ponder.frankencoin.com
NEXT_PUBLIC_MORPHOGRAPH_URL=https://blue-api.morpho.org/graphql

NEXT_PUBLIC_PROFILE=mainnet
NEXT_PUBLIC_WAGMI_ID=<your-reown-project-id>

NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# --- Server-side RPC proxy ---
# Server-only (no NEXT_PUBLIC_ prefix) — consumed exclusively by
# pages/api/rpc/[chain].ts and never inlined into the client bundle.
# Wagmi transports in app.config.ts route every chain read through
# /api/rpc/<chain>, so these URLs and the Alchemy fallback key stay
# server-side. NEVER commit real upstream URLs here; put them in
# .env.local (gitignored) or a hosting provider's secret store.
RPC_MAINNET=https://eth-mainnet.example.com
RPC_POLYGON=https://polygon-mainnet.example.com
RPC_ARBITRUM=https://arbitrum-mainnet.example.com
RPC_OPTIMISM=https://optimism-mainnet.example.com
RPC_BASE=https://base-mainnet.example.com
RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_GNOSIS=https://gnosis-mainnet.example.com
RPC_SONIC=https://sonic-mainnet.example.com
# Optional shared secret added to every upstream request as
# `Authorization: Bearer ...`. Set this once a Caddy reverse proxy in
# front of the self-hosted nodes enforces it; harmless to leave blank.
RPC_PROXY_SECRET=
# Alchemy key used as a one-shot fallback when the primary upstream
# returns 5xx or times out. Server-side only.
RPC_FALLBACK_ALCHEMY_KEY=<your-alchemy-key>
