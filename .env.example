# Frankenterminal — independent Frankencoin frontend

NEXT_PUBLIC_LANDINGPAGE_URL=https://frankencoin.com
NEXT_PUBLIC_APP_URL=https://frankenterminal.app
NEXT_PUBLIC_API_URL=https://api.frankencoin.com
NEXT_PUBLIC_PONDER_URL=https://ponder.frankencoin.com
NEXT_PUBLIC_MORPHOGRAPH_URL=https://blue-api.morpho.org/graphql

NEXT_PUBLIC_PROFILE=mainnet
NEXT_PUBLIC_WAGMI_ID=<your-reown-project-id>

NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# --- Server-side RPC proxy ---
# The proxy at pages/api/rpc/[chain].ts tries the public-RPC list in
# rpc.config.ts (committed in the repo because those URLs are non-secret)
# first, and only falls through to Alchemy on 5xx / transport error. This
# keeps the Alchemy free-tier CU budget for actual outages rather than
# routine traffic. The key is server-only — no NEXT_PUBLIC_ prefix —
# and never inlined into the client bundle. Verify with the bundle grep
# in HANDOFF.md §3.1.
RPC_ALCHEMY_KEY=<your-alchemy-key>
